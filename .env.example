APP_DOMAIN=meuagente.seu-dominio.com.br
CORS_ORIGINS=https://meuagente.seu-dominio.com.br

POSTGRES_HOST=vector-db
POSTGRES_PORT=5432
POSTGRES_DB=meuagente
POSTGRES_USER=meuagente
POSTGRES_PASSWORD=troque-esta-senha

MEUAGENTE_DEFAULT_PROVIDER=openai
MEUAGENTE_LLM_MODEL=gpt-4.1-mini
MEUAGENTE_EMBEDDER_MODEL=text-embedding-3-small
MEUAGENTE_GEMINI_LLM_MODEL=gemini-2.0-flash
MEUAGENTE_GEMINI_EMBEDDER_MODEL=gemini-embedding-exp-03-07
MEUAGENTE_WHATSAPP_VERIFY_TOKEN=troque-este-token

FRONTEND_IMAGE=meuagente-frontend:latest
BACKEND_IMAGE=meuagente-backend:latest
WHATSAPP_IMAGE=meuagente-whatsapp:latest
VECTOR_DB_IMAGE=pgvector/pgvector:pg17

TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERTRESOLVER=letsencryptresolver
TRAEFIK_DOCKER_NETWORK=waianet

BACKEND_VOLUME_NAME=meuagente_backend_data
WHATSAPP_VOLUME_NAME=meuagente_whatsapp_data
VECTOR_VOLUME_NAME=meuagente_vector_db_data
